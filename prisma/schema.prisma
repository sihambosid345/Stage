generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  LEFT
}

enum Gender {
  MALE
  FEMALE
}

enum ContractType {
  CDI
  CDD
  STAGE
  INTERIM
  FREELANCE
  OTHER
}

enum ContractStatus {
  DRAFT
  ACTIVE
  ENDED
  SUSPENDED
  TERMINATED
}

enum PayrollPeriodStatus {
  OPEN
  PROCESSING
  CLOSED
  LOCKED
}

enum PayrollRunStatus {
  DRAFT
  PROCESSING
  COMPLETED
  CANCELLED
}

enum PayrollItemType {
  BASE_SALARY
  ALLOWANCE
  BONUS
  OVERTIME
  DEDUCTION
  ADVANCE
  TAX
  CNSS
  OTHER
}

enum VariableItemType {
  ALLOWANCE
  BONUS
  DEDUCTION
  ADVANCE
  OVERTIME
  OTHER
}

enum VariableValueType {
  FIXED
  PERCENTAGE
  HOURS
  DAYS
}

enum VariableItemStatus {
  PENDING
  APPROVED
  REJECTED
  APPLIED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  SICK_LEAVE
  PAID_LEAVE
  UNPAID_LEAVE
  HOLIDAY
  OTHER
}

enum PayslipStatus {
  DRAFT
  GENERATED
  SENT
  CANCELLED
}

enum LicensePlanCode {
  BASIC
  PRO
  BUSINESS
  ENTERPRISE
}

enum LicenseStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
}

enum BillingCycle {
  MONTHLY
  YEARLY
  LIFETIME
}

model Company {
  id                 String          @id @default(uuid())
  name               String
  legalName          String?
  taxIdentifier      String?
  rcNumber           String?
  iceNumber          String?
  cnssNumber         String?
  email              String?
  phone              String?
  address            String?
  city               String?
  country            String?         @default("Maroc")
  timezone           String?         @default("Africa/Casablanca")
  currency           String?         @default("MAD")
  status             CompanyStatus   @default(ACTIVE)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  users              User[]
  employees          Employee[]
  departments        Department[]
  positions          Position[]
  payrollPeriods     PayrollPeriod[]
  payrollRuns        PayrollRun[]
  variableItems      VariableItem[]
  attendanceRecords  AttendanceRecord[]
  payslips           Payslip[]
  license            License?
  auditLogs          AuditLog[]
  employeeContracts  EmployeeContract[]  // ✅ relation manquante ajoutée
  payrollItems       PayrollItem[]       // ✅ relation manquante ajoutée

  @@index([status])
  @@map("companies")
}

model Department {
  id          String     @id @default(uuid())
  companyId   String
  name        String
  code        String?
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees   Employee[]
  positions   Position[] // ✅ relation manquante ajoutée

  @@unique([companyId, name])
  @@index([companyId, isActive])
  @@map("departments")
}

model Position {
  id           String      @id @default(uuid())
  companyId    String
  departmentId String?
  name         String
  code         String?
  description  String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull) // ✅ relation opposée ajoutée dans Department
  employees    Employee[]

  @@unique([companyId, name])
  @@index([companyId, departmentId, isActive])
  @@map("positions")
}

model User {
  id             String      @id @default(uuid())
  companyId      String
  firstName      String
  lastName       String
  fullName       String?
  email          String
  phone          String?
  passwordHash   String
  role           String
  status         UserStatus  @default(ACTIVE)
  lastLoginAt    DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdPeriods PayrollPeriod[] @relation("PayrollPeriodCreatedBy")
  createdRuns    PayrollRun[]    @relation("PayrollRunCreatedBy")
  approvedRuns   PayrollRun[]    @relation("PayrollRunApprovedBy")
  variableItems  VariableItem[]  @relation("VariableItemCreatedBy")
  auditLogs      AuditLog[]

  @@unique([companyId, email])
  @@index([companyId, role, status])
  @@map("users")
}

model Employee {
  id                  String          @id @default(uuid())
  companyId           String
  employeeCode        String?
  firstName           String
  lastName            String
  fullName            String?
  cin                 String?
  cnssNumber          String?
  matricule           String?
  gender              Gender?
  birthDate           DateTime?
  phone               String?
  email               String?
  address             String?
  city                String?
  hireDate            DateTime
  terminationDate     DateTime?
  status              EmployeeStatus  @default(ACTIVE)

  departmentId        String?
  positionId          String?

  baseSalary          Decimal?        @db.Decimal(12, 2)
  paymentMode         String?
  bankName            String?
  bankAccountNumber   String?

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  company             Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department          Department?     @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  position            Position?       @relation(fields: [positionId], references: [id], onDelete: SetNull)

  contracts           EmployeeContract[]
  variableItems       VariableItem[]
  attendanceRecords   AttendanceRecord[]
  payrollItems        PayrollItem[]
  payslips            Payslip[]

  @@unique([companyId, employeeCode])
  @@unique([companyId, cin])
  @@index([companyId, status])
  @@index([companyId, departmentId])
  @@index([companyId, positionId])
  @@map("employees")
}

model EmployeeContract {
  id                    String          @id @default(uuid())
  companyId             String
  employeeId            String
  contractType          ContractType
  status                ContractStatus  @default(DRAFT)

  startDate             DateTime
  endDate               DateTime?
  baseSalary            Decimal         @db.Decimal(12, 2)

  hoursPerMonth         Decimal?        @db.Decimal(8, 2)
  workingDaysPerMonth   Decimal?        @db.Decimal(8, 2)

  notes                 String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  employee              Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company               Company         @relation(fields: [companyId], references: [id], onDelete: Cascade) // ✅ relation opposée ajoutée dans Company

  @@index([companyId, employeeId, status])
  @@index([employeeId, startDate, endDate])
  @@map("employee_contracts")
}

model PayrollPeriod {
  id               String               @id @default(uuid())
  companyId        String
  year             Int
  month            Int
  startDate        DateTime
  endDate          DateTime
  status           PayrollPeriodStatus  @default(OPEN)
  isLocked         Boolean              @default(false)
  notes            String?

  createdById      String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  company          Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy        User?                @relation("PayrollPeriodCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  payrollRuns      PayrollRun[]
  payslips         Payslip[]

  @@unique([companyId, year, month])
  @@index([companyId, status])
  @@map("payroll_periods")
}

model PayrollRun {
  id                    String            @id @default(uuid())
  companyId             String
  payrollPeriodId       String
  runNumber             Int               @default(1)
  status                PayrollRunStatus  @default(DRAFT)

  totalEmployees        Int               @default(0)
  totalGross            Decimal           @default(0) @db.Decimal(14, 2)
  totalDeductions       Decimal           @default(0) @db.Decimal(14, 2)
  totalNet              Decimal           @default(0) @db.Decimal(14, 2)

  createdById           String?
  approvedById          String?
  approvedAt            DateTime?
  startedAt             DateTime?
  completedAt           DateTime?
  notes                 String?

  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  company               Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payrollPeriod         PayrollPeriod     @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  createdBy             User?             @relation("PayrollRunCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  approvedBy            User?             @relation("PayrollRunApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  payrollItems          PayrollItem[]
  payslips              Payslip[]

  @@unique([payrollPeriodId, runNumber])
  @@index([companyId, payrollPeriodId, status])
  @@map("payroll_runs")
}

model PayrollItem {
  id                 String           @id @default(uuid())
  companyId          String
  payrollRunId       String
  employeeId         String
  itemType           PayrollItemType
  code               String?
  label              String
  quantity           Decimal?         @db.Decimal(10, 2)
  rate               Decimal?         @db.Decimal(12, 2)
  amount             Decimal          @db.Decimal(12, 2)
  taxable            Boolean          @default(false)
  cnssApplicable     Boolean          @default(false)
  sortOrder          Int              @default(0)
  metadata           Json?

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  company            Company          @relation(fields: [companyId], references: [id], onDelete: Cascade) // ✅ relation opposée ajoutée dans Company
  payrollRun         PayrollRun       @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee           Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId, payrollRunId])
  @@index([employeeId, itemType])
  @@map("payroll_items")
}

model VariableItem {
  id                  String              @id @default(uuid())
  companyId           String
  employeeId          String
  type                VariableItemType
  valueType           VariableValueType   @default(FIXED)
  code                String?
  label               String
  quantity            Decimal?            @db.Decimal(10, 2)
  unitValue           Decimal?            @db.Decimal(12, 2)
  percentageValue     Decimal?            @db.Decimal(8, 2)
  amount              Decimal             @db.Decimal(12, 2)

  effectiveDate       DateTime
  payrollPeriodId     String?
  status              VariableItemStatus  @default(PENDING)
  notes               String?

  createdById         String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  company             Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee            Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy           User?               @relation("VariableItemCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([companyId, employeeId, type])
  @@index([companyId, effectiveDate, status])
  @@map("variable_items")
}

model AttendanceRecord {
  id                String            @id @default(uuid())
  companyId         String
  employeeId        String
  date              DateTime
  status            AttendanceStatus
  workedHours       Decimal?          @db.Decimal(8, 2)
  overtimeHours     Decimal?          @db.Decimal(8, 2)
  lateMinutes       Int?
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  company           Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee          Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([companyId, date])
  @@map("attendance_records")
}

model Payslip {
  id                    String          @id @default(uuid())
  companyId             String
  employeeId            String
  payrollPeriodId       String
  payrollRunId          String?
  status                PayslipStatus   @default(DRAFT)

  grossSalary           Decimal         @default(0) @db.Decimal(12, 2)
  totalAllowances       Decimal         @default(0) @db.Decimal(12, 2)
  totalBonuses          Decimal         @default(0) @db.Decimal(12, 2)
  totalDeductions       Decimal         @default(0) @db.Decimal(12, 2)
  totalAdvances         Decimal         @default(0) @db.Decimal(12, 2)
  totalTax              Decimal         @default(0) @db.Decimal(12, 2)
  totalCnss             Decimal         @default(0) @db.Decimal(12, 2)
  netSalary             Decimal         @default(0) @db.Decimal(12, 2)

  currency              String?         @default("MAD")
  pdfPath               String?
  pdfGeneratedAt        DateTime?
  sentAt                DateTime?
  snapshotData          Json?

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  company               Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee              Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payrollPeriod         PayrollPeriod   @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  payrollRun            PayrollRun?     @relation(fields: [payrollRunId], references: [id], onDelete: SetNull)

  @@unique([employeeId, payrollPeriodId])
  @@index([companyId, payrollPeriodId, status])
  @@map("payslips")
}

model License {
  id                  String           @id @default(uuid())
  companyId           String           @unique
  planCode            LicensePlanCode
  status              LicenseStatus    @default(TRIAL)
  billingCycle        BillingCycle     @default(MONTHLY)

  maxUsers            Int?
  maxEmployees        Int?
  maxStorageMb        Int?

  payrollEnabled      Boolean          @default(true)
  rhEnabled           Boolean          @default(true)
  cnssEnabled         Boolean          @default(false)
  taxEnabled          Boolean          @default(false)
  damancomEnabled     Boolean          @default(false)

  startsAt            DateTime
  endsAt              DateTime?
  lastRenewedAt       DateTime?
  notes               String?

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  company             Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([status, planCode])
  @@index([startsAt, endsAt])
  @@map("licenses")
}

model AuditLog {
  id            String    @id @default(uuid())
  companyId     String
  userId        String?
  action        String
  entityType    String
  entityId      String?
  description   String?
  metadata      Json?
  createdAt     DateTime  @default(now())

  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, entityType, entityId])
  @@index([companyId, action, createdAt])
  @@map("audit_logs")
}